<?xml version="1.0" ?>
<robot name="ironx_3d_camera"
  xmlns:xacro="http://ros.org/wiki/xacro">

  <link name="base_footprint"/>

<!-- start ironx_structure -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.0235" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/ironx_structure.stl"/>
      </geometry>
      <material name="c1"> 
        <color rgba="0.149 0.149 0.149 1.0"/> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry>
        <box size="0.268 0.258 0.160"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="8.2573504e-01"/>
      <inertia ixx="2.2124416e-03" ixy="-1.2294101e-05" ixz="3.4938785e-05" iyy="2.1193702e-03" iyz="-5.0120904e-06" izz="2.0064271e-03" />
    </inertial>
  </link>
<!-- end ironx_structure -->

<!-- start wheel_1 -->
  <joint name="wheel_1_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_1_link"/>
    <!-- <limit effort = "30" velocity="10"/> -->
    <origin xyz="0.0745 0.0915 0.048" rpy="0 0 0"/>
    <!-- <axis xyz="0 0 1"/> -->
  </joint>

  <link name="wheel_1_link">
    <visual>
      <origin xyz="0 0 -0.048" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/wheel_1.stl"/>
      </geometry>
      <material name="c2"> 
        <color rgba="0.498 0.498 0.498 1" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.048"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
    </inertial>
  </link>
<!-- end wheel_1 -->

<!-- start wheel_2 -->
  <joint name="wheel_2_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_2_link"/>
    <limit effort = "30" velocity="10"/>
    <origin xyz="0.0745 -0.0915 0.048" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_2_link">
    <visual>
      <origin xyz="0 0 -0.048" rpy="0 0 3.1416"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/wheel_2.stl"/>
      </geometry>
      <material name="c3"> 
        <color rgba="0.498 0.498 0.498 1" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.048"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
    </inertial>
  </link>
<!-- end wheel_2 -->

<!-- start wheel_3 -->
  <joint name="wheel_3_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_3_link"/>
    <limit effort = "30" velocity="10"/>
    <origin xyz="-0.0745 0.0915 0.048" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="wheel_3_link">
    <visual>
      <origin xyz="0 0 -0.048" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/wheel_3.stl"/>
      </geometry>
      <material name="c4"> 
        <color rgba="0.498 0.498 0.498 1" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.048"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
    </inertial>
  </link>
<!-- end wheel_3 -->

<!-- start wheel_4 -->
  <joint name="wheel_4_joint" type="fixed">
    <parent link="base_link"/>
    <child link="wheel_4_link"/>
    <!-- <limit effort = "30" velocity="10"/> -->
    <origin xyz="-0.0745 -0.0915 0.048" rpy="0 0 0"/>
    <!-- <axis xyz="0 0 1"/> -->
  </joint>

  <link name="wheel_4_link">
    <visual>
      <origin xyz="0 0 -0.048" rpy="0 0 3.1416"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/wheel_4.stl"/>
      </geometry>
      <material name="c5"> 
        <color rgba="0.498 0.498 0.498 1" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.05" radius="0.048"/>
      </geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0" />
      <mass value="2.8498940e-02" />
      <inertia ixx="1.1175580e-05" ixy="-4.2369783e-11" ixz="-5.9381719e-09" iyy="1.1192413e-05" iyz="-1.4400107e-11" izz="2.0712558e-05" />
    </inertial>
  </link>
<!-- end wheel_4 -->

<!-- start imu -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="-0.065 -0.013 0.080" rpy="0 0 0"/>
  </joint>

  <link name="imu_link">
    
  </link>
<!-- end imu -->

<!-- start scan -->
  <joint name="scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="base_scan"/>
    <origin xyz="0.025 0 0.145" rpy="0 0 3.14"/>
  </joint>

  <link name="base_scan">
    <visual>
      <origin xyz="0 0 -0.035" rpy="0 0 3.14"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/lidar.stl"/>
      </geometry>
      <material name="c6"> 
        <color rgba="0.498 0.498 0.498 1.0" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.0315" radius="0.055"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.114" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
    </inertial>
  </link>
<!-- end scan -->

<!-- start camera3d -->
  <joint name="camera3d_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.112 0 0.16" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://ironx_description/meshes/stl/3d_camera.stl"/>
      </geometry>
      <material name="c7"> 
        <color rgba="0.356 0.203 0.2 1" /> 
			</material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder length="0.0315" radius="0.055"/>
      </geometry>
    </collision>

    <inertial>
      <mass value="0.114" />
      <origin xyz="0 0 0" />
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001" />
    </inertial>
  </link>
<!-- end camera3d -->

</robot>
